pipeline {
    agent any

    environment {
        EC2_HOST   = '16.112.148.230'
        EC2_USER   = 'ec2-user'
        JAR_NAME   = 'RevPay.jar'
        DEPLOY_DIR = '/home/ec2-user'
        SERVICE    = 'revpay'
    }

    tools {
        jdk   'JDK-21'
        maven 'Maven-3.9'
    }

    stages {

        stage('Checkout') {
            steps {
                echo "📥 Checking out code..."
                checkout scm
                bat 'git rev-parse --short HEAD'
            }
        }

        stage('Build') {
            steps {
                echo '🔨 Building JAR...'
                bat 'mvn clean package -DskipTests'
            }
            post {
                success { echo '✅ Build passed!' }
                failure { error '❌ Build failed — stopping.' }
            }
        }

        stage('Test') {
            steps {
                echo '🧪 Running tests...'
                bat 'mvn test'
            }
            post {
                always {
                    junit testResults: 'target/surefire-reports/*.xml',
                          allowEmptyResults: true
                }
                success { echo '✅ Tests passed!' }
                failure { error '❌ Tests failed — deployment blocked.' }
            }
        }

        stage('Deploy to EC2') {
            steps {
                echo "🚀 Deploying to EC2..."
                sshagent(credentials: ['ec2-ssh-key']) {

                    // Upload JAR to EC2
                    bat """
                        scp -o StrictHostKeyChecking=no ^
                            target\\RevPay-0.0.1-SNAPSHOT.jar ^
                            %EC2_USER%@%EC2_HOST%:%DEPLOY_DIR%/RevPay-new.jar
                    """

                    // SSH and swap JAR
                    bat """
                        ssh -o StrictHostKeyChecking=no %EC2_USER%@%EC2_HOST% ^
                        "sudo systemctl stop %SERVICE% ; ^
                        cp %DEPLOY_DIR%/%JAR_NAME% %DEPLOY_DIR%/RevPay-backup.jar 2>/dev/null || true ; ^
                        mv %DEPLOY_DIR%/RevPay-new.jar %DEPLOY_DIR%/%JAR_NAME% ; ^
                        sudo systemctl start %SERVICE%"
                    """
                }
            }
            post {
                failure {
                    echo '❌ Deploy failed — rolling back!'
                    sshagent(credentials: ['ec2-ssh-key']) {
                        bat """
                            ssh -o StrictHostKeyChecking=no %EC2_USER%@%EC2_HOST% ^
                            "cp %DEPLOY_DIR%/RevPay-backup.jar %DEPLOY_DIR%/%JAR_NAME% && ^
                            sudo systemctl restart %SERVICE% && ^
                            echo Rollback done"
                        """
                    }
                }
            }
        }

        stage('Health Check') {
            steps {
                echo '🏥 Checking app health...'
                sshagent(credentials: ['ec2-ssh-key']) {
                    bat """
                        ssh -o StrictHostKeyChecking=no %EC2_USER%@%EC2_HOST% ^
                        "sleep 15 && sudo systemctl is-active %SERVICE% && echo App is LIVE || exit 1"
                    """
                }
            }
        }
    }

    post {
        success {
            echo "✅ DEPLOYMENT SUCCESSFUL → http://${EC2_HOST}:8080"
        }
        failure {
            echo "❌ PIPELINE FAILED — check console output above"
        }
        always {
            cleanWs()
        }
    }
}